<!DOCTYPE html>
<html>
<head>

<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Checklist | Untitled World</title>

<style>

body{
margin:0;
font-family:Outfit,sans-serif;
background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);
color:white;
}

.app{
max-width:420px;
margin:auto;
padding:20px;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:20px;
}

.addBtn{
background:#00ff88;
border:none;
padding:10px 14px;
border-radius:10px;
font-weight:bold;
cursor:pointer;
transition:0.2s;
}

.addBtn:hover{
transform:scale(1.1);
background:#00e67a;
}

.task{
display:flex;
align-items:center;
justify-content:space-between;
background:rgba(255,255,255,.07);
padding:14px;
border-radius:14px;
margin-bottom:12px;
backdrop-filter:blur(12px);
opacity:0;
transform:translateY(15px);
animation:slideUp .35s forwards;
}

@keyframes slideUp{
to{
opacity:1;
transform:translateY(0);
}
}

.task.done{
opacity:.5;
text-decoration:line-through;
}

.task span{
flex:1;
margin-left:10px;
}

.delete{
background:none;
border:none;
color:#ff4d4d;
font-size:18px;
cursor:pointer;
}

.delete:hover{
color:#ff1a1a;
transform:scale(1.2);
}

.empty{
text-align:center;
opacity:.5;
margin-top:40px;
}

</style>

</head>

<body>

<div class="app">

<header>

<h2>Today's Checklist</h2>

<button class="addBtn" onclick="addTask()">＋</button>

</header>

<div id="taskList"></div>

</div>

<script type="module" src="checklist.js"></script>

</body>
</html>